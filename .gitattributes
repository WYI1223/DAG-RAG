# Auto detect text files and normalize line endings to LF in the repo.
# Each OS checks out in its native format (CRLF on Windows, LF on Mac/Linux).
* text=auto

# Force LF for source code (ensures consistent diffs across platforms)
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.ico binary
